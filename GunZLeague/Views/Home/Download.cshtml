        <section class="site-card download-panel">
            <h1>Download GunZ League</h1>
            <p>Download the current beta client from one of the mirrors below.</p>

            <div class="download-actions">
                <a class="btn btn-danger btn-lg" href="https://disk.yandex.com/d/hX4ao-fIRLXYOg" target="_blank" rel="noopener noreferrer">Download from Yandex</a>
