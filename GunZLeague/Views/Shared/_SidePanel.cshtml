@using Microsoft.AspNetCore.Http
@inject IConfiguration Configuration
@{
    var loggedUser = Context.Session.GetString("UserName");
    var streamLinks = Configuration.GetSection("Community:Streams").Get<string[]>() ?? Array.Empty<string>();
}

<aside class="side-column">
    <div class="login-panel">
        @if (string.IsNullOrEmpty(loggedUser))
        {
            <div class="login-header">
                <h2>Login</h2>
            </div>
            <form asp-controller="Account" asp-action="Login" method="post">
                @Html.AntiForgeryToken()

                <div class="login-field">
                    <label class="form-label" for="sideUserId">Username</label>
                    <input class="form-control" id="sideUserId" name="userId" maxlength="20" placeholder="Enter your username" autocomplete="username" required />
                </div>

                <div class="login-field">
                    <label class="form-label" for="sidePassword">Password</label>
                    <input class="form-control" id="sidePassword" name="password" type="password" maxlength="20" placeholder="Enter your password" autocomplete="current-password" required />
                </div>

                <button class="btn btn-danger w-100 login-submit" type="submit">Log in</button>
            </form>
            <div class="login-meta">
                <a asp-controller="Account" asp-action="ForgotPassword">Forgot password?</a>
            </div>
        }
        else
        {
            <div class="login-header">
                <h2>Account</h2>
            </div>
            <div class="account-summary account-summary-card">
                <div>
                    <span>Logged in as</span>
                    <strong>@loggedUser</strong>
                </div>
            </div>
            <a class="btn btn-danger w-100 account-primary-action" asp-controller="Account" asp-action="Profile">Open profile</a>
            <form class="account-logout-form" asp-controller="Account" asp-action="Logout" method="post">
                @Html.AntiForgeryToken()
                <button class="btn btn-outline-light w-100" type="submit">Log out</button>
            </form>
        }
    </div>

    <a class="discord-panel" href="https://discord.com/invite/k6paY32BSs" target="_blank" rel="noopener">
        <span class="discord-logo" aria-hidden="true">
            <svg viewBox="0 0 48 48" role="img">
                <path d="M15.7 14.5c2.5-1.1 5.2-1.6 8.3-1.6s5.8.5 8.3 1.6c2.7 3.7 4 7.8 4.4 12.3-2.9 2.2-5.7 3.4-8.5 3.8l-1-2.1c1.1-.4 2.1-.9 3-1.5-1.9.9-3.9 1.3-6.2 1.3s-4.3-.4-6.2-1.3c.9.6 1.9 1.1 3 1.5l-1 2.1c-2.8-.4-5.6-1.6-8.5-3.8.4-4.5 1.7-8.6 4.4-12.3Zm3.6 9.4c1.1 0 1.9-1 1.9-2.1s-.8-2.1-1.9-2.1-1.9 1-1.9 2.1.8 2.1 1.9 2.1Zm9.4 0c1.1 0 1.9-1 1.9-2.1s-.8-2.1-1.9-2.1-1.9 1-1.9 2.1.8 2.1 1.9 2.1Z" />
            </svg>
        </span>
        <span>
            <small>Community</small>
            <strong>Join our Discord</strong>
        </span>
    </a>

    @if (streamLinks.Length > 0)
    {
        <section class="streams-panel" data-streams-panel data-streams-url="@Url.Action("Streams", "Community")">
            <div class="streams-panel-header">
                <span class="twitch-logo" aria-hidden="true">
                    <svg viewBox="0 0 24 24" role="img">
                        <path d="M4.3 2 3 5.6v14.1h4.8V22h2.7l2.3-2.3h3.7L21 15.2V2H4.3Zm14.9 12.3-2.8 2.8h-4.2L9.9 19.4v-2.3H6.2V3.8h13v10.5Zm-3.2-7v5.3h-1.8V7.3H16Zm-4.8 0v5.3H9.4V7.3h1.8Z" />
                    </svg>
                </span>
                <span>
                    <small>Community</small>
                    <h2>Streams</h2>
                </span>
            </div>

            @foreach (var streamLink in streamLinks)
            {
                if (!Uri.TryCreate(streamLink, UriKind.Absolute, out var streamUri))
                {
                    continue;
                }

                var channelName = streamUri.Segments.LastOrDefault()?.Trim('/') ?? streamUri.Host;
                var displayName = string.IsNullOrWhiteSpace(channelName) ? streamUri.Host : channelName;

                <a class="streamer-card" href="@streamLink" target="_blank" rel="noopener" data-streamer-card data-channel="@channelName.ToLowerInvariant()">
                    <span class="streamer-status" aria-hidden="true" data-streamer-status></span>
                    <span>
                        <small data-streamer-state>Checking Twitch</small>
                        <strong data-streamer-name>@displayName</strong>
                        <em data-streamer-meta></em>
                    </span>
                </a>
            }
        </section>
    }
</aside>
