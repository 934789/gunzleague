@model IEnumerable<GunZLeague.Models.GunZ.Clan>
@{
    ViewData["Title"] = "Clan ranking";
    var sort = (string)ViewBag.CurrentSort;
    var search = ViewBag.Search as string ?? string.Empty;
    var currentPage = (int)ViewBag.CurrentPage;
    var totalPages = (int)ViewBag.TotalPages;
}

<section class="page-shell">
    <div class="page-main">
        <section class="rank-simple-header">
            <span class="eyebrow">Ranking</span>
            <h1>Clan ranking</h1>
            <div class="tabs rank-tabs">
                <a asp-action="Index">Rank</a>
                <a asp-action="Player">Player</a>
                <a class="active" asp-action="Clan">Clan</a>
                <a asp-action="PlayerWars">Player Wars</a>
            </div>
        </section>

        <div class="rank-toolbar rank-search-toolbar">
            <form class="rank-search-form" asp-action="Clan" method="get">
                <input type="hidden" name="sort" value="@sort" />
                <input class="form-control" type="search" name="q" value="@search" maxlength="24" placeholder="Search clan" />
                <button class="btn btn-danger" type="submit">Search</button>
                @if (!string.IsNullOrWhiteSpace(search))
                {
                    <a class="btn btn-outline-light" asp-action="Clan" asp-route-sort="@sort">Clear</a>
                }
            </form>
            <div class="tabs">
                <a class="@(sort == "points" ? "active" : "")" asp-action="Clan" asp-route-sort="points" asp-route-q="@search">Points</a>
                <a class="@(sort == "wins" ? "active" : "")" asp-action="Clan" asp-route-sort="wins" asp-route-q="@search">Wins</a>
            </div>
        </div>

        <div class="table-shell rank-table-shell">
            <table class="table rank-table align-middle mb-0">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Clan</th>
                        <th>Points</th>
                        <th>Wins</th>
                        <th>Losses</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        var position = ((currentPage - 1) * 10) + 1;
                    }
                    @foreach (var clan in Model)
                    {
                        var rankClass = position <= 3 ? $"rank-top-{position}" : string.Empty;
                        <tr>
                            <td><span class="rank-number @rankClass">@position</span></td>
                            <td>
                                <div class="rank-clan-cell">
                                    <span class="rank-clan-emblem" aria-hidden="true">
                                        @if (!string.IsNullOrWhiteSpace(clan.EmblemUrl))
                                        {
                                            <img src="/gunzweb/clan_emblem/@($"{clan.EmblemUrl}?v={clan.EmblemChecksum ?? 0}")" alt="" onerror="this.onerror=null; this.src='/img/no_emblem.png';" />
                                        }
                                        else
                                        {
                                            <img src="/img/no_emblem.png" alt="No Emblem" />
                                        }
                                    </span>
                                    <a class="table-entity-link" asp-action="ClanDetails" asp-route-id="@clan.CLID">
                                        @clan.Name
                                    </a>
                                </div>
                            </td>
                            <td>@clan.Point</td>
                            <td>@clan.WinCount</td>
                            <td>@clan.LoseCount</td>
                        </tr>
                        position++;
                    }
                </tbody>
            </table>
        </div>

        @if (!Model.Any())
        {
            <div class="empty-state mt-3">No clans found.</div>
        }

        <div class="pager-row">
            @if (currentPage > 1)
            {
                <a class="btn btn-outline-light" asp-action="Clan" asp-route-sort="@sort" asp-route-q="@search" asp-route-page="@(currentPage - 1)">Previous</a>
            }
            <span>Page @currentPage of @(Math.Max(totalPages, 1))</span>
            @if (currentPage < totalPages)
            {
                <a class="btn btn-outline-light" asp-action="Clan" asp-route-sort="@sort" asp-route-q="@search" asp-route-page="@(currentPage + 1)">Next</a>
            }
        </div>
    </div>
    <partial name="_SidePanel" />
</section>
