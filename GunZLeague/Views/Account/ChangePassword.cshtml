@model GunZLeague.Models.ViewModels.ChangePasswordViewModel
@{
    ViewData["Title"] = "Change password";
    var userName = ViewBag.UserName as string;
}

<div class="account-password-page">
    <section class="site-card password-panel">
        <a class="auth-link text-start mt-0 mb-3" asp-action="Profile">Back to my account</a>

        <h1>Change password</h1>

        <form asp-action="ChangePassword" method="post" class="password-form">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <label class="form-label" asp-for="CurrentPassword">Current password</label>
            <input class="form-control" asp-for="CurrentPassword" maxlength="20" autocomplete="current-password" />
            <span class="text-danger" asp-validation-for="CurrentPassword"></span>

            <label class="form-label mt-3" asp-for="NewPassword">New password</label>
            <input class="form-control" asp-for="NewPassword" minlength="4" maxlength="20" autocomplete="new-password" />
            <span class="text-danger" asp-validation-for="NewPassword"></span>

            <label class="form-label mt-3" asp-for="ConfirmPassword">Confirm new password</label>
            <input class="form-control" asp-for="ConfirmPassword" minlength="4" maxlength="20" autocomplete="new-password" />
            <span class="text-danger" asp-validation-for="ConfirmPassword"></span>

            <div class="password-actions">
                <button class="btn btn-danger" type="submit">Save password</button>
                <a class="btn btn-outline-light" asp-action="Profile">Cancel</a>
            </div>
        </form>
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
