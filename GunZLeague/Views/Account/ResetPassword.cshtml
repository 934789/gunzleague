@model GunZLeague.Models.ViewModels.ResetPasswordViewModel
@{
    ViewData["Title"] = "Reset password";
    var tokenInvalid = ViewBag.TokenInvalid as bool? ?? false;
}

<div class="auth-page">
    <div class="auth-card">
        <h1>Reset password</h1>

        @if (tokenInvalid)
        {
            <p class="muted-text">This password reset link is invalid or expired.</p>
            <a class="btn btn-danger w-100 mt-3" asp-action="ForgotPassword">Request a new link</a>
        }
        else
        {
            <form asp-action="ResetPassword" method="post">
                @Html.AntiForgeryToken()
                <input asp-for="Token" type="hidden" />

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <label class="form-label" asp-for="NewPassword">New password</label>
                <input class="form-control" asp-for="NewPassword" minlength="4" maxlength="20" autocomplete="new-password" />
                <span class="text-danger" asp-validation-for="NewPassword"></span>

                <label class="form-label mt-3" asp-for="ConfirmPassword">Confirm new password</label>
                <input class="form-control" asp-for="ConfirmPassword" minlength="4" maxlength="20" autocomplete="new-password" />
                <span class="text-danger" asp-validation-for="ConfirmPassword"></span>

                <button class="btn btn-danger w-100 mt-4" type="submit">Save new password</button>
            </form>
        }
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
