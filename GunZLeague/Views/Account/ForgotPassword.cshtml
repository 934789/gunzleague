@model GunZLeague.Models.ViewModels.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Forgot password";
}

<div class="auth-page">
    <form class="auth-card" asp-action="ForgotPassword" method="post">
        @Html.AntiForgeryToken()

        <h1>Forgot password</h1>
        <p class="muted-text">Enter the email linked to your account.</p>

        @if (TempData["ForgotPasswordMessage"] != null)
        {
            <div class="alert alert-success">@TempData["ForgotPasswordMessage"]</div>
        }

        @if (TempData["DevResetLink"] != null)
        {
            <div class="alert alert-warning reset-dev-link">
                <strong>Development reset link</strong>
                <a href="@TempData["DevResetLink"]">@TempData["DevResetLink"]</a>
            </div>
        }

        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <label class="form-label" asp-for="Email">Email</label>
        <input class="form-control" asp-for="Email" maxlength="50" autocomplete="email" />
        <span class="text-danger" asp-validation-for="Email"></span>

        <button class="btn btn-danger w-100 mt-4" type="submit">Send reset link</button>
        <a class="auth-link" asp-action="Login">Back to login</a>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
